<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <Nullable>disable</Nullable>
    <ImplicitUsings>disable</ImplicitUsings>
    <AssemblyName>LumenAuth</AssemblyName>
    <RootNamespace>LumenAuth</RootNamespace>
    <PackageId>LumenAuth</PackageId>
    <Version>1.0.0</Version>
    <Authors>LumenAuth</Authors>
    <Description>Official C# SDK for LumenAuth — license auth, HWID locking and license-gated downloads for desktop apps.</Description>
    <RepositoryUrl>https://lumenauth.dev</RepositoryUrl>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="System.Text.Json" Version="8.0.5" />
  </ItemGroup>

</Project>
